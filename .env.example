# App
APP_ENV=development
APP_PORT=8080
APP_NAME=marketplace

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=marketplace
DB_PASSWORD=marketplace_secret
DB_NAME=marketplace
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Meilisearch
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=meili_master_key_change_me

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_BUCKET=marketplace
MINIO_USE_SSL=false

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Firebase
FIREBASE_CREDENTIALS_FILE=./firebase-service-account.json

# SMS (MSG91 / Twilio)
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_ID=

# Admin
ADMIN_EMAIL=admin@marketplace.com
ADMIN_PASSWORD=admin123

# NextJS Admin
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_MINIO_URL=http://localhost:9000
